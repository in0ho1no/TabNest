<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="TabNest.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TabNest.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.KeyboardAccelerators>
            <!--  ショートカットはウィンドウのルート要素に設定する(SPEC「ショートカットキー」)  -->
            <KeyboardAccelerator
                Key="T"
                Invoked="AddTabAccelerator_Invoked"
                Modifiers="Control" />
            <KeyboardAccelerator
                Key="G"
                Invoked="AddGroupAccelerator_Invoked"
                Modifiers="Control" />
            <KeyboardAccelerator
                Key="T"
                Invoked="RestoreClosedTabAccelerator_Invoked"
                Modifiers="Control,Shift" />
            <KeyboardAccelerator
                Key="W"
                Invoked="CloseActiveTabAccelerator_Invoked"
                Modifiers="Control" />
            <KeyboardAccelerator
                Key="Left"
                Invoked="NavigateBackAccelerator_Invoked"
                Modifiers="Menu" />
            <KeyboardAccelerator
                Key="Right"
                Invoked="NavigateForwardAccelerator_Invoked"
                Modifiers="Menu" />
            <KeyboardAccelerator
                Key="Up"
                Invoked="NavigateUpAccelerator_Invoked"
                Modifiers="Menu" />
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <!--
            The Frame hosts pages for your application content. Add your UI to
            MainPage.xaml rather than here so you can use Page features such as
            navigation events and the Loaded lifecycle.
        -->
        <Frame x:Name="RootFrame" Grid.Row="1" />
    </Grid>
</Window>
