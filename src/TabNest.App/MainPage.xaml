<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TabNest.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TabNest.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:TabNest.App.Controls"
    xmlns:vm="using:TabNest.ViewModels"
    mc:Ignorable="d">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  タブグループ行(グループごとに1段)  -->
        <ItemsControl
            Grid.Row="0"
            Margin="0,0,0,8"
            AutomationProperties.AutomationId="TabGroupsList"
            ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:TabGroupViewModel">
                    <controls:TabGroupRow />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  ナビゲーションバー(戻る・進む・上へ・アドレスバー)  -->
        <Grid Grid.Row="1" Margin="0,0,0,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="BackButton"
                Grid.Column="0"
                AutomationProperties.AutomationId="BackButton"
                Command="{x:Bind ViewModel.Folder.BackCommand, Mode=OneWay}"
                Content="&#xE72B;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="戻る" />
            <Button
                x:Name="ForwardButton"
                Grid.Column="1"
                AutomationProperties.AutomationId="ForwardButton"
                Command="{x:Bind ViewModel.Folder.ForwardCommand, Mode=OneWay}"
                Content="&#xE72A;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="進む" />
            <Button
                x:Name="UpButton"
                Grid.Column="2"
                AutomationProperties.AutomationId="UpButton"
                Command="{x:Bind ViewModel.Folder.NavigateUpCommand, Mode=OneWay}"
                Content="&#xE74A;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="上の階層へ" />
            <TextBox
                x:Name="PathTextBox"
                Grid.Column="3"
                AutomationProperties.AutomationId="PathTextBox"
                KeyDown="PathTextBox_KeyDown"
                Text="{x:Bind ViewModel.Folder.AddressBarText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <!--  エラー表示  -->
        <InfoBar
            x:Name="ErrorInfoBar"
            Grid.Row="2"
            Margin="0,0,0,8"
            AutomationProperties.AutomationId="ErrorInfoBar"
            IsOpen="{x:Bind local:MainPage.HasText(ViewModel.Folder.ErrorMessage), Mode=OneWay}"
            Message="{x:Bind ViewModel.Folder.ErrorMessage, Mode=OneWay}"
            Severity="Error" />

        <!--  自前ヘッダー行(WinUI 3 では DataGrid 系を使わない方針)  -->
        <Grid
            Grid.Row="3"
            Padding="16,0,16,4"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="140" />
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="90" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Grid.Column="0"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="名前" />
            <TextBlock
                Grid.Column="1"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="種別" />
            <TextBlock
                Grid.Column="2"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="更新日時" />
            <TextBlock
                Grid.Column="3"
                HorizontalAlignment="Right"
                Style="{ThemeResource CaptionTextBlockStyle}"
                Text="サイズ" />
        </Grid>

        <!--  ファイル一覧  -->
        <ListView
            x:Name="FileListView"
            Grid.Row="4"
            AutomationProperties.AutomationId="FileListView"
            DoubleTapped="FileListView_DoubleTapped"
            ItemsSource="{x:Bind ViewModel.Folder.Items, Mode=OneWay}"
            SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:FileItemViewModel">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            Text="{x:Bind Name}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="1"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind TypeText}" />
                        <TextBlock
                            Grid.Column="2"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind LastModifiedText}" />
                        <TextBlock
                            Grid.Column="3"
                            HorizontalAlignment="Right"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind SizeText}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
