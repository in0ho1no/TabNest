<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TabNest.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TabNest.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:TabNest.App.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:TabNest.ViewModels"
    mc:Ignorable="d">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  タブグループ行(グループごとに1段)  -->
        <ItemsControl
            Grid.Row="0"
            Margin="0,0,0,8"
            AutomationProperties.AutomationId="TabGroupsList"
            ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:TabGroupViewModel">
                    <controls:TabGroupRow />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  ナビゲーションバー(戻る・進む・上へ・アドレスバー・タブ追加・グループ追加)  -->
        <Grid Grid.Row="1" Margin="0,0,0,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="BackButton"
                Grid.Column="0"
                AutomationProperties.AutomationId="BackButton"
                Command="{x:Bind ViewModel.Folder.BackCommand, Mode=OneWay}"
                Content="&#xE72B;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="戻る" />
            <Button
                x:Name="ForwardButton"
                Grid.Column="1"
                AutomationProperties.AutomationId="ForwardButton"
                Command="{x:Bind ViewModel.Folder.ForwardCommand, Mode=OneWay}"
                Content="&#xE72A;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="進む" />
            <Button
                x:Name="UpButton"
                Grid.Column="2"
                AutomationProperties.AutomationId="UpButton"
                Command="{x:Bind ViewModel.Folder.NavigateUpCommand, Mode=OneWay}"
                Content="&#xE74A;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="上の階層へ" />
            <TextBox
                x:Name="PathTextBox"
                Grid.Column="3"
                AutomationProperties.AutomationId="PathTextBox"
                KeyDown="PathTextBox_KeyDown"
                Text="{x:Bind ViewModel.Folder.AddressBarText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                x:Name="AddTabButton"
                Grid.Column="4"
                AutomationProperties.AutomationId="AddTabButton"
                Command="{x:Bind ViewModel.AddTabCommand, Mode=OneWay}"
                Content="タブ追加"
                ToolTipService.ToolTip="アクティブグループの末尾に新規タブを追加 (Ctrl+T)" />
            <Button
                x:Name="AddGroupButton"
                Grid.Column="5"
                AutomationProperties.AutomationId="AddGroupButton"
                Command="{x:Bind ViewModel.AddGroupCommand, Mode=OneWay}"
                Content="グループ追加"
                ToolTipService.ToolTip="タブグループを1段追加 (Ctrl+G)" />
        </Grid>

        <!--  エラー表示  -->
        <StackPanel Grid.Row="2">
            <InfoBar
                x:Name="ErrorInfoBar"
                Margin="0,0,0,8"
                AutomationProperties.AutomationId="ErrorInfoBar"
                IsOpen="{x:Bind local:MainPage.HasText(ViewModel.Folder.ErrorMessage), Mode=OneWay}"
                Message="{x:Bind ViewModel.Folder.ErrorMessage, Mode=OneWay}"
                Severity="Error" />
            <InfoBar
                x:Name="OperationErrorInfoBar"
                Margin="0,0,0,8"
                AutomationProperties.AutomationId="OperationErrorInfoBar"
                IsOpen="{x:Bind local:MainPage.HasText(ViewModel.OperationError), Mode=OneWay}"
                Message="{x:Bind ViewModel.OperationError, Mode=OneWay}"
                Severity="Error" />
        </StackPanel>

        <!--  メインコンテンツ: 左カラム(お気に入り+フォルダツリー) | スプリッター | ファイル一覧  -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    x:Name="LeftPaneColumn"
                    Width="220"
                    MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  左カラム: 上=お気に入り(Task 4-6 で実装)、下=フォルダツリー  -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel
                    Grid.Row="0"
                    Padding="8"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <TextBlock
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="★ お気に入り" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="(Task 4-6 で実装予定)" />
                </StackPanel>
                <TreeView
                    x:Name="FolderTreeView"
                    Grid.Row="1"
                    AutomationProperties.AutomationId="FolderTreeView"
                    CanDragItems="False"
                    CanReorderItems="False"
                    ItemInvoked="FolderTreeView_ItemInvoked"
                    ItemsSource="{x:Bind ViewModel.Tree.Roots, Mode=OneWay}"
                    SelectionMode="Single">
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="vm:FolderTreeNodeViewModel">
                            <TreeViewItem
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                IsSelected="{x:Bind IsSelected, Mode=TwoWay}"
                                ItemsSource="{x:Bind Children}">
                                <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>

            <!--  スプリッター(CommunityToolkit.WinUI GridSplitter・依存追加承認済み)  -->
            <toolkit:GridSplitter
                Grid.Column="1"
                Width="8"
                AutomationProperties.AutomationId="LeftPaneSplitter"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Auto" />

            <!--  右側: ヘッダー行+ファイル一覧  -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  自前ヘッダー行(WinUI 3 では DataGrid 系を使わない方針)  -->
                <Grid
                    Grid.Row="0"
                    Padding="16,0,16,4"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="292" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="1"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="名前" />
                    <TextBlock
                        Grid.Column="2"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="種別" />
                    <TextBlock
                        Grid.Column="3"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="更新日時" />
                    <TextBlock
                        Grid.Column="4"
                        HorizontalAlignment="Right"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="サイズ" />
                </Grid>

                <!--  ファイル一覧  -->
                <ListView
                    x:Name="FileListView"
                    Grid.Row="1"
                    AutomationProperties.AutomationId="FileListView"
                    DoubleTapped="FileListView_DoubleTapped"
                    ItemsSource="{x:Bind ViewModel.Folder.Items, Mode=OneWay}"
                    SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:FileItemViewModel">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="292" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            FontSize="16"
                            Glyph="{x:Bind IconGlyph}" />
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind Name}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="2"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind TypeText}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="3"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind LastModifiedText}" />
                        <TextBlock
                            Grid.Column="4"
                            HorizontalAlignment="Right"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind SizeText}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
