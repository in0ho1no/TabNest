<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="TabNest.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:TabNest.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:TabNest.App.Controls"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:vm="using:TabNest.ViewModels"
    mc:Ignorable="d">

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  タブグループ行(グループごとに1段)  -->
        <ItemsControl
            x:Name="TabGroupsList"
            Grid.Row="0"
            Margin="0,0,0,8"
            AutomationProperties.AutomationId="TabGroupsList"
            ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}">
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:TabGroupViewModel">
                    <controls:TabGroupRow />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!--  ナビゲーションバー(戻る・進む・上へ・アドレスバー・タブ追加・グループ追加)  -->
        <Grid Grid.Row="1" Margin="0,0,0,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button
                x:Name="BackButton"
                Grid.Column="0"
                AutomationProperties.AutomationId="BackButton"
                Command="{x:Bind ViewModel.Folder.BackCommand, Mode=OneWay}"
                Content="&#xE72B;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="戻る" />
            <Button
                x:Name="ForwardButton"
                Grid.Column="1"
                AutomationProperties.AutomationId="ForwardButton"
                Command="{x:Bind ViewModel.Folder.ForwardCommand, Mode=OneWay}"
                Content="&#xE72A;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="進む" />
            <Button
                x:Name="UpButton"
                Grid.Column="2"
                AutomationProperties.AutomationId="UpButton"
                Command="{x:Bind ViewModel.Folder.NavigateUpCommand, Mode=OneWay}"
                Content="&#xE74A;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                ToolTipService.ToolTip="上の階層へ" />
            <ToggleButton
                x:Name="ToggleFolderTreeButton"
                Grid.Column="3"
                AutomationProperties.AutomationId="ToggleFolderTreeButton"
                AutomationProperties.Name="フォルダツリーの表示切替"
                Content="&#xEC50;"
                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                IsChecked="{x:Bind ViewModel.IsFolderTreeVisible, Mode=TwoWay}"
                ToolTipService.ToolTip="フォルダツリーの表示/非表示" />
            <TextBox
                x:Name="PathTextBox"
                Grid.Column="4"
                AutomationProperties.AutomationId="PathTextBox"
                KeyDown="PathTextBox_KeyDown"
                Text="{x:Bind ViewModel.Folder.AddressBarText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <Button
                x:Name="AddTabButton"
                Grid.Column="5"
                AutomationProperties.AutomationId="AddTabButton"
                Command="{x:Bind ViewModel.AddTabCommand, Mode=OneWay}"
                Content="タブ追加"
                ToolTipService.ToolTip="アクティブグループの末尾に新規タブを追加 (Ctrl+T)" />
            <Button
                x:Name="AddGroupButton"
                Grid.Column="6"
                AutomationProperties.AutomationId="AddGroupButton"
                Command="{x:Bind ViewModel.AddGroupCommand, Mode=OneWay}"
                Content="グループ追加"
                ToolTipService.ToolTip="タブグループを1段追加 (Ctrl+G)" />
        </Grid>

        <!--  エラー表示  -->
        <StackPanel Grid.Row="2">
            <InfoBar
                x:Name="ErrorInfoBar"
                Margin="0,0,0,8"
                AutomationProperties.AutomationId="ErrorInfoBar"
                IsOpen="{x:Bind local:MainPage.HasText(ViewModel.Folder.ErrorMessage), Mode=OneWay}"
                Message="{x:Bind ViewModel.Folder.ErrorMessage, Mode=OneWay}"
                Severity="Error" />
            <InfoBar
                x:Name="OperationErrorInfoBar"
                Margin="0,0,0,8"
                AutomationProperties.AutomationId="OperationErrorInfoBar"
                IsOpen="{x:Bind local:MainPage.HasText(ViewModel.OperationError), Mode=OneWay}"
                Message="{x:Bind ViewModel.OperationError, Mode=OneWay}"
                Severity="Error" />
        </StackPanel>

        <!--  メインコンテンツ: 左カラム(お気に入り+フォルダツリー) | スプリッター | ファイル一覧  -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition
                    x:Name="LeftPaneColumn"
                    Width="220"
                    MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  左カラム: 上=お気に入り、下=フォルダツリー(独立した2領域)  -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel
                    Grid.Row="0"
                    Padding="8"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <TextBlock
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Text="★ お気に入り" />
                    <!--  保存順で表示し、収まらない場合は縦スクロール(SPEC「お気に入り」)  -->
                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                        <ListView
                            x:Name="FavoritesListView"
                            AllowDrop="True"
                            AutomationProperties.AutomationId="FavoritesListView"
                            CanDragItems="True"
                            CanReorderItems="True"
                            DragItemsCompleted="FavoritesListView_DragItemsCompleted"
                            IsItemClickEnabled="True"
                            ItemClick="FavoritesListView_ItemClick"
                            ItemsSource="{x:Bind ViewModel.Favorites, Mode=OneWay}"
                            ScrollViewer.VerticalScrollMode="Disabled"
                            SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="MinHeight" Value="32" />
                                    <Setter Property="Padding" Value="8,0" />
                                    <!--  Grid 等は AutomationPeer を持たないため、UIA から見える項目側に付与する  -->
                                    <Setter Property="AutomationProperties.AutomationId" Value="FavoriteItem" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:FavoriteItemViewModel">
                                    <Grid Background="Transparent">
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem
                                                    AutomationProperties.AutomationId="RenameFavoriteMenuItem"
                                                    Click="RenameFavorite_Click"
                                                    Text="名前の変更" />
                                                <MenuFlyoutItem
                                                    AutomationProperties.AutomationId="DeleteFavoriteMenuItem"
                                                    Click="DeleteFavorite_Click"
                                                    Text="削除" />
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Text="{x:Bind Name, Mode=OneWay}"
                                            TextTrimming="CharacterEllipsis"
                                            Visibility="{x:Bind local:MainPage.VisibleWhenNot(IsEditingName), Mode=OneWay}" />
                                        <TextBox
                                            x:Name="FavoriteNameEditBox"
                                            MinWidth="80"
                                            VerticalAlignment="Center"
                                            AutomationProperties.AutomationId="FavoriteNameEditBox"
                                            KeyDown="FavoriteNameEditBox_KeyDown"
                                            LostFocus="FavoriteNameEditBox_LostFocus"
                                            Text="{x:Bind EditingName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                            Visibility="{x:Bind local:MainPage.VisibleWhen(IsEditingName), Mode=OneWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                </StackPanel>
                <TreeView
                    x:Name="FolderTreeView"
                    Grid.Row="1"
                    AutomationProperties.AutomationId="FolderTreeView"
                    CanDragItems="False"
                    CanReorderItems="False"
                    ItemInvoked="FolderTreeView_ItemInvoked"
                    Loaded="FolderTreeView_Loaded"
                    ItemsSource="{x:Bind ViewModel.Tree.Roots, Mode=OneWay}"
                    SelectionMode="Single"
                    Visibility="{x:Bind local:MainPage.VisibleWhen(ViewModel.IsFolderTreeVisible), Mode=OneWay}">
                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="vm:FolderTreeNodeViewModel">
                            <TreeViewItem
                                IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                IsSelected="{x:Bind IsSelected, Mode=TwoWay}"
                                ItemsSource="{x:Bind Children}">
                                <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                            </TreeViewItem>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>

            <!--  スプリッター(CommunityToolkit.WinUI GridSplitter・依存追加承認済み)  -->
            <toolkit:GridSplitter
                Grid.Column="1"
                Width="8"
                AutomationProperties.AutomationId="LeftPaneSplitter"
                ResizeBehavior="BasedOnAlignment"
                ResizeDirection="Auto" />

            <!--  右側: ヘッダー行+ファイル一覧  -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  自前ヘッダー行(WinUI 3 では DataGrid 系を使わない方針)  -->
                <!--  タイトルクリックで昇順・降順切り替え、区切りダブルクリックで列幅自動調整  -->
                <Grid
                    x:Name="FileListHeader"
                    Grid.Row="0"
                    Padding="16,0,16,4"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
                    <Grid.Resources>
                        <Style x:Key="ColumnHeaderButtonStyle" TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding" Value="0,2" />
                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                        </Style>
                        <!--
                            区切りは UIA から検出できるよう Button にする
                            (Rectangle 等の Shape は AutomationPeer を持たず UI テストで操作できない)。
                            8px の透明領域でダブルクリックを受け付けつつ、右端に視認できる区切り線を描く
                            (区切り位置が分かり、その位置のダブルクリックで列幅を自動調整できる。Task 6-5)。
                        -->
                        <Style x:Key="ColumnSeparatorStyle" TargetType="Button">
                            <Setter Property="Width" Value="8" />
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Setter Property="VerticalAlignment" Value="Stretch" />
                            <Setter Property="IsTabStop" Value="False" />
                            <Setter Property="UseSystemFocusVisuals" Value="False" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="Transparent">
                                            <Rectangle
                                                Width="1"
                                                HorizontalAlignment="Right"
                                                Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Grid.Resources>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="28" />
                        <ColumnDefinition Width="292" />
                        <ColumnDefinition Width="140" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="90" />
                    </Grid.ColumnDefinitions>
                    <Button
                        Grid.Column="1"
                        AutomationProperties.AutomationId="NameColumnHeader"
                        Click="NameColumnHeader_Click"
                        Style="{StaticResource ColumnHeaderButtonStyle}">
                        <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="名前" />
                    </Button>
                    <Button
                        Grid.Column="2"
                        AutomationProperties.AutomationId="TypeColumnHeader"
                        Click="TypeColumnHeader_Click"
                        Style="{StaticResource ColumnHeaderButtonStyle}">
                        <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="種別" />
                    </Button>
                    <Button
                        Grid.Column="3"
                        AutomationProperties.AutomationId="LastModifiedColumnHeader"
                        Click="LastModifiedColumnHeader_Click"
                        Style="{StaticResource ColumnHeaderButtonStyle}">
                        <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="更新日時" />
                    </Button>
                    <Button
                        Grid.Column="4"
                        AutomationProperties.AutomationId="SizeColumnHeader"
                        Click="SizeColumnHeader_Click"
                        HorizontalContentAlignment="Right"
                        Style="{StaticResource ColumnHeaderButtonStyle}">
                        <TextBlock Style="{ThemeResource CaptionTextBlockStyle}" Text="サイズ" />
                    </Button>
                    <!--  列の区切り(右端 8px)。ダブルクリックで表示文字列に応じて列幅を自動調整する  -->
                    <Button
                        Grid.Column="1"
                        AutomationProperties.AutomationId="NameColumnSeparator"
                        DoubleTapped="NameColumnSeparator_DoubleTapped"
                        Style="{StaticResource ColumnSeparatorStyle}" />
                    <Button
                        Grid.Column="2"
                        AutomationProperties.AutomationId="TypeColumnSeparator"
                        DoubleTapped="TypeColumnSeparator_DoubleTapped"
                        Style="{StaticResource ColumnSeparatorStyle}" />
                    <Button
                        Grid.Column="3"
                        AutomationProperties.AutomationId="LastModifiedColumnSeparator"
                        DoubleTapped="LastModifiedColumnSeparator_DoubleTapped"
                        Style="{StaticResource ColumnSeparatorStyle}" />
                    <Button
                        Grid.Column="4"
                        AutomationProperties.AutomationId="SizeColumnSeparator"
                        DoubleTapped="SizeColumnSeparator_DoubleTapped"
                        Style="{StaticResource ColumnSeparatorStyle}" />
                </Grid>

                <!--  ファイル一覧  -->
                <ListView
                    x:Name="FileListView"
                    Grid.Row="1"
                    AutomationProperties.AutomationId="FileListView"
                    ContainerContentChanging="FileListView_ContainerContentChanging"
                    DoubleTapped="FileListView_DoubleTapped"
                    ItemsSource="{x:Bind ViewModel.Folder.Items, Mode=OneWay}"
                    SelectionMode="Single">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:FileItemViewModel">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="292" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="90" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            Grid.Column="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontFamily="{ThemeResource SymbolThemeFontFamily}"
                            FontSize="16"
                            Glyph="{x:Bind IconGlyph}" />
                        <TextBlock
                            Grid.Column="1"
                            Text="{x:Bind Name}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="2"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind TypeText}"
                            TextTrimming="CharacterEllipsis" />
                        <TextBlock
                            Grid.Column="3"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind LastModifiedText}" />
                        <TextBlock
                            Grid.Column="4"
                            HorizontalAlignment="Right"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind SizeText}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
